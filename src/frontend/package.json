{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -c -- ts-node server.ts",
    "build": "next build && tsc --project tsconfig.server.json && mv dist/server.js dist/server.cjs",
    "start": "NODE_ENV=production dotenv -c -- node dist/server.cjs",
    "lint": "eslint",
    "fix": "eslint . --fix && prettier . --write"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "mediasoup-client": "^3.18.1",
    "next": "^16.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/webrtc": "^0.0.47",
    "baseline-browser-mapping": "^2.9.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
